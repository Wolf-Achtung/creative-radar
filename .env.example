# ---------------------------------------------------------------------------
# Creative Radar — Backend ENV-Beispiel
# Diese Datei spiegelt app/config.py Settings. Alle Schlüssel sind in Großbuchstaben
# (pydantic-settings ist case-insensitive). Werte sind Defaults oder Platzhalter.
# Lokal nach `.env` kopieren, in Railway als ENV-Variablen pflegen.
# ---------------------------------------------------------------------------

# --- App ---
APP_ENV=production
APP_NAME=creative-radar

# --- Datenbank ---
# Railway Postgres setzt DATABASE_URL automatisch, sobald Postgres mit dem Backend verbunden ist.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Optionale Railway-spezifische Varianten (eine reicht):
DATABASE_PRIVATE_URL=
DATABASE_PUBLIC_URL=
# Fallback auf einzelne PG*-Variablen, falls keine *_URL gesetzt ist:
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=
# Nur für lokale Entwicklung ohne Postgres aktivieren — niemals in Production.
ALLOW_SQLITE_FALLBACK=false

# --- CORS / URLs ---
# Für den MVP kann CORS_ORIGINS zunächst * bleiben. Später auf Netlify-/App-Domain einschränken.
CORS_ORIGINS=*
FRONTEND_URL=https://DEINE-NETLIFY-URL.netlify.app
BACKEND_URL=https://DEINE-RAILWAY-URL.up.railway.app

# --- OpenAI ---
# Übernimmt Creative-Zusammenfassung einzelner Assets und Report-Summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Perplexity (optional) ---
# Nur für spätere externe Trend-/Recherchekontexte. Sparsam einsetzen.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# --- TMDb ---
# Whitelist-Quelle für Filme/Serien (siehe Roadmap MVP-Scope).
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# --- Apify ---
# Scraper für Instagram/TikTok. Token aus Apify Console.
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR_ID=apify~instagram-scraper
APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-scraper
APIFY_RESULTS_LIMIT_PER_CHANNEL=5
APIFY_WAIT_SECONDS=60

# --- Reports ---
REPORT_TIMEZONE=Europe/Berlin

# --- Secure Storage (Phase 4 W2: R2-Adapter aktiviert dies) ---
SECURE_STORAGE_ENABLED=false

# --- Image-Proxy ---
# Komma-separierte Liste erlaubter Host-Suffixe (CDN-Hostnamen).
IMAGE_PROXY_ALLOWED_HOSTS=cdninstagram.com,fbcdn.net,tiktokcdn.com,tiktokcdn-us.com,tiktokcdn-eu.com
IMAGE_PROXY_TIMEOUT_SECONDS=8.0
IMAGE_PROXY_MAX_BYTES=8388608
