APP_ENV=production
APP_NAME=creative-radar

# Railway Postgres setzt DATABASE_URL automatisch, sobald Postgres mit dem Backend verbunden ist.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Für den MVP kann CORS_ORIGINS zunächst * bleiben. Später auf Netlify-URL einschränken.
CORS_ORIGINS=*
FRONTEND_URL=https://DEINE-NETLIFY-URL.netlify.app
BACKEND_URL=https://DEINE-RAILWAY-URL.up.railway.app

# OpenAI übernimmt die Creative-Zusammenfassung einzelner Assets und die Report-Summary.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Perplexity ist optional und nur für spätere externe Trend-/Recherchekontexte gedacht.
# In v1 nicht für jeden Einzelpost nutzen, sondern sparsam für wöchentliche Markt-Kontextrecherche.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

REPORT_TIMEZONE=Europe/Berlin
